    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate-assets": "node scripts/generate-asset-manifest.js",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "scrape": "echo 'Scraping functionality has been removed'",
    "update-materials": "node scripts/update-material-picker.js",
    "postinstall": "node scripts/fix-react-exports.js && node scripts/fix-react-dom-exports.js && prisma generate",
    "check-react": "node -e \"console.log('React version:', require('react/package.json').version); const fs = require('fs'); const path = require('path'); const reactPath = path.dirname(require.resolve('react/package.json')); const prodFile = path.join(reactPath, 'cjs/react.production.min.js'); const jsxFile = path.join(reactPath, 'cjs/react-jsx-runtime.production.min.js'); if (fs.existsSync(prodFile)) { console.log('✓ React production CJS exists'); } else { console.error('✗ React production CJS missing'); } if (fs.existsSync(jsxFile)) { console.log('✓ React JSX runtime CJS exists'); } else { console.error('✗ React JSX runtime CJS missing'); }\""
  },
